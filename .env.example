# Source DB (read-only, simulated production DB)
SOURCE_DB_URL=postgresql://source_user:source_pass@localhost:5432/crm_source

# Sidecar DB (our controlled analytics layer)
SIDECAR_DB_URL=postgresql://sidecar_user:sidecar_pass@localhost:5433/crm_sidecar

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI model selection (haiku = cheap, sonnet = quality)
AI_MODEL=claude-3-haiku-20240307

# Alert system
ALERT_SCAN_INTERVAL_MINUTES=60

# Optional: Slack webhook for at-risk digest
SLACK_WEBHOOK_URL=
